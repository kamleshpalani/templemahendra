# frontend/.env.example
# Copy to .env.local for local dev (already proxied by Vite — leave blank)
# In Vercel dashboard: Settings → Environment Variables → add these

# URL of the PHP backend on Render.
# Leave EMPTY for local dev (Vite proxies /api → localhost:8000 automatically).
# Example: https://temple-mahendra-api.onrender.com/api
VITE_API_URL=
