# Files and folders to exclude from version control

# Environment secrets — never commit real values
backend/.env
backend/**/.env
frontend/.env.local
.env.local
frontend/.env.*.local
.env

# Uploaded files (manage via Hostinger, not git)
backend/uploads/*
!backend/uploads/.gitkeep

# Temporary one-off scripts (never commit DB seeds with credentials)
_seed_aiven.mjs
_seed_*.mjs
_setup_*.php

# Node
frontend/node_modules/
frontend/dist/

# OS
.DS_Store
Thumbs.db
