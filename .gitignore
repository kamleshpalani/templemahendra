# Files and folders to exclude from version control

# Environment secrets — never commit real values
backend/.env
backend/**/.env
frontend/.env.local
frontend/.env.production
frontend/.env.*.local
.env

# Uploaded files (manage via Hostinger, not git)
backend/uploads/*
!backend/uploads/.gitkeep

# Node
frontend/node_modules/
frontend/dist/

# OS
.DS_Store
Thumbs.db
