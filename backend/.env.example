# .env.example — Copy to .env and fill in real values
# NEVER commit the real .env to version control

DB_HOST=localhost
DB_NAME=templemahendra
DB_USER=your_db_username
DB_PASS=your_db_password

# Admin credentials
# Generate hash with: php -r "echo password_hash('YourPassword', PASSWORD_BCRYPT);"
ADMIN_USERNAME=admin
ADMIN_PASS_HASH=$2y$12$REPLACE_THIS_WITH_REAL_BCRYPT_HASH

# CORS — in production set to your Vercel URL, e.g. https://temple-mahendra.vercel.app
CORS_ORIGIN=https://your-app.vercel.app

# Google Gemini AI — chatbot (get free key at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=AIza_your_key_here

# Google Places API — for Google Reviews on homepage
# Step 1: Get API key at https://console.cloud.google.com/ → APIs & Services → Credentials
#         Enable: "Places API"
# Step 2: Find your Place ID at https://developers.google.com/maps/documentation/javascript/examples/places-placeid-finder
#         Search: "Dhabbalavaar Renuka Devi Lingamma Sinnammal Temple Pudupatti"
GOOGLE_PLACES_API_KEY=YOUR_GOOGLE_PLACES_API_KEY
GOOGLE_PLACE_ID=ChIJ_YOUR_PLACE_ID_HERE
