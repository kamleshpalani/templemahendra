# Exclude everything that doesn't belong inside the container

# Frontend (served by Vercel, not Render)
frontend/

# Deployment config files (not needed inside image)
deploy/
Dockerfile
.dockerignore
render.yaml
*.md

# Version control
.git/
.github/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
*.code-workspace

# Secrets — never bake into the image
backend/.env
**/.env
**/.env.local
**/.env.production

# Uploaded files — should be mounted as a volume or stored in a CDN
backend/uploads/*
!backend/uploads/.gitkeep

# Node (shouldn't be here, but guard anyway)
node_modules/
